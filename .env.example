# ── Groq API (GRATUITO) ───────────────────────────────────────────────────────
# Crie sua chave em: https://console.groq.com/keys
# Free tier: 14.400 requests/dia, 131K tokens/request
GROQ_API_KEY=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

# Modelo Groq a usar (padrão: llama-3.3-70b-versatile)
# Opções gratuitas: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ── Helius API (opcional, mas recomendado) ────────────────────────────────────
# Dados on-chain enriquecidos. Crie em: https://dev.helius.xyz/
# Sem ela, usa Solscan + RPC público da Solana como fallback
HELIUS_API_KEY=f8b23779-13b7-4225-8213-7030c5e5341d

# ── Solscan API (opcional) ────────────────────────────────────────────────────
# Melhora a busca de TXs e carteiras. Sem key usa a API pública gratuita.
# Crie em: https://pro-api.solscan.io/
# Sem key: usa public-api.solscan.io (gratuito, sem autenticação)
